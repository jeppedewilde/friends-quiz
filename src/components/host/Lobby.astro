<div id="wachtScherm" class="lobby-scherm">
    <h1>Lobby</h1>
    <p>Wie is de grootste friends fan? Test het nu!</p>

    <div class="content-wrapper">
        <div class="krijtbord">
            <div class="qr-sectie">
                <h2>Scan de qr code en join!</h2>
                <div id="qrcode" class="qr-box"></div>
            </div>
            <div>
                <h2>Spelers</h2>
                <div id="messages" class="spelers-lijst"></div>
                <img src="/images/central_perk_logo.png" alt="Central Perk logo">
            </div>
        </div>
    </div>

    <div id="cast_wrapper">
        <img src="/images/ross.png" alt="Ross Geller Face">
        <img src="/images/monica.png" alt="Monica Geller Face">
        <img src="/images/chandler.png" alt="Chandler Bing Face">
        <img src="/images/joey.png" alt="Joey Tribbiani Face">
        <img src="/images/rachel.png" alt="Rachel Green Face">
        <img src="/images/phoebe.png" alt="Phoebe Buffay Face">
    </div>

    <button id="startGameBtn" class="start-knop">Start quiz</button>

    <div style="display: none;">
        <input type="text" id="message" placeholder="Type a message">
        <button id="send">Stuur</button>
    </div>
</div>

<!-- qrcode.js library inladen -->
<script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script>

<!-- genereer QR code -->
<script is:inline>
    // functie om de qr te maken, wordt meteen uitgevoerd
    (function maakQR() {
        const qrBox = document.getElementById("qrcode");
        
        // als element nog niet klaar is na 50ms weer proberen
        if (!qrBox) {
            setTimeout(maakQR, 50);
            return;
        }
        
        // maak de qr code met de URL van de speelpagina
        qrBox.innerHTML = ''; 
        const speelUrl = `http://${window.location.host}/play`;
        
        // styling qr code
        new QRCode(qrBox, {
            text: speelUrl,
            width: 400,
            height: 400,
            colorDark : "#ffffff",
            colorLight : "transparent",
            correctLevel : QRCode.CorrectLevel.H
        });
    })();
</script>

<script>
    const startKnop = document.querySelector('.start-knop');
    const castHoofden = document.querySelectorAll('#cast_wrapper img');

    // lijstje om actieve animatie bij te houden
    let actieveAnimaties = [];

    // bij hover
    startKnop?.addEventListener('mouseenter', () => {
        
        // ga langs elk cast hoofd
        castHoofden.forEach((hoofd, index) => {
            
            // web animations API
            const springAnimatie = hoofd.animate(
                [
                    { transform: "translateY(0px)" },
                    { transform: "translateY(-30px)" },
                    { transform: "translateY(0px)" }
                ],
                {
                    duration: 600,
                    iterations: Infinity,
                    easing: "ease-in-out",
                    delay: index * 100,
                    composite: "add"
                }
            );
            
            // bewaar de animatie in lijstje
            actieveAnimaties.push(springAnimatie);
        });
    });

    // bij stoppen hover
    startKnop?.addEventListener('mouseleave', () => {
        // stop de animatie direct
        actieveAnimaties.forEach(animatie => animatie.cancel());
        
        // maak lijstje weer leeg
        actieveAnimaties = [];
    });
</script>

