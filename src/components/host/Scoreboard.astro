---

<div id="eindScherm" class="hidden scoreboard-container">
    <h1 id="scoreboardTitel">The One Who Won The Quiz</h1>
    
    <div id="scoreLijst" class="score-lijst"></div>
    
    <button id="terugNaarQuizBtn" class="hidden terug-button">Terug naar de quiz</button>
    <button id="restartBtn" class="restart-button">Terug naar lobby</button>
</div>

<style>
    .scoreboard-container {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 2rem;
        font-family: sans-serif;
    }

    h1 {
        font-size: 2rem;
        margin-bottom: 1.5rem;
    }

    .score-lijst {
        width: 100%;
        max-width: 400px;
        background-color: #f9f9f9;
        border: 1px solid #ddd;
        border-radius: 8px;
        padding: 1rem;
    }

    .quote {
        margin-top: 2rem;
        font-style: italic;
        color: #666;
    }

    .restart-button {
        margin-top: 1.5rem;
        padding: 10px 20px;
        font-size: 1rem;
        background-color: #333;
        color: white;
        border: none;
        border-radius: 4px;
        cursor: pointer;
    }

    .restart-button:hover {
        background-color: #555;
    }

    /* Dynamische rijen (ingeladen door JS) */
    :global(.speler-rij) {
        display: flex;
        justify-content: space-between;
        padding: 10px;
        border-bottom: 1px solid #eee;
        color: #333;
    }

    :global(.speler-rij:last-child) {
        border-bottom: none;
    }

    :global(.winnaar) {
        font-weight: bold;
        background-color: #e6f7ff; 
        border-radius: 4px;
    }

    .hidden {
        display: none !important;
    }

    .terug-button {
        margin-top: 1.5rem;
        padding: 10px 20px;
        font-size: 1rem;
        background-color: #26890c;
        color: white;
        border: none;
        border-radius: 4px;
        cursor: pointer;
    }

</style>